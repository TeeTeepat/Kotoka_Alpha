generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Deck {
  id           String   @id @default(cuid())
  userId       String?
  sceneDesc    String
  emotionScore Int      @default(50)
  atmosphere   String   @default("ambient")
  ambientSound String   @default("cafe")
  note         String?
  colorPalette String   @default("#1ad3e2")
  createdAt    DateTime @default(now())
  locationLat  Float?
  locationLng  Float?
  locationName String?
  imageBase64  String?   @db.Text
  words        Word[]
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Word {
  id             String    @id @default(cuid())
  deckId         String
  word           String
  translation    String
  example        String
  difficulty     String
  phonetic       String
  masteryCount   Int       @default(0)
  easeFactor     Float     @default(2.5)
  interval       Int       @default(1)
  nextReviewAt   DateTime  @default(now())
  lastReviewedAt DateTime?
  deck           Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

model User {
  id                 String      @id @default(cuid())
  name               String?
  email              String?     @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  hearts             Int         @default(5)
  streak             Int         @default(0)
  coins              Int         @default(150)
  streakFreezeActive Boolean     @default(false)
  targetLanguage     String?
  learningLanguage        String?
  initialLearningLanguage String?
  cefrLevel          String?
  lastSessionNodeId  String?
  lastSessionSkill   String?
  lastSessionProgress Int?
  lastSessionStartedAt DateTime?
  completedNodes     Int         @default(0)
  timezone           String?     @default("UTC")
  lastStreakDate     String?
  lastHeartAt        DateTime?
  isOnboarded        Boolean     @default(false)
  age                Int?
  job                String?
  salary             String?
  createdAt          DateTime    @default(now())
  gachaItems         GachaItem[]
  accounts           Account[]
  sessions           Session[]
  decks              Deck[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GachaItem {
  id       String   @id @default(cuid())
  userId   String
  type     String
  name     String
  rarity   String
  emoji    String
  pulledAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConversationSession {
  id             String    @id @default(cuid())
  userId         String
  scenarioType   String
  targetWords    String[]
  exchanges      Json      @default("[]")
  wordsCompleted String[]
  coinsAwarded   Int       @default(0)
  accuracy       Float     @default(0)
  durationSec    Int       @default(0)
  correctChoices Int       @default(0)
  totalChoices   Int       @default(0)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
}

model WeeklyStory {
  id           String   @id @default(cuid())
  userId       String
  weekNumber   Int
  storyText    String   @db.Text
  wordsUsed    String[]
  reflectionQ  String
  language     String   @default("en")
  createdAt    DateTime @default(now())

  @@unique([userId, weekNumber])
}

model LeaderboardEntry {
  id            String   @id @default(cuid())
  userId        String
  cefrLevel     String
  weekNumber    Int
  wordsMastered Int      @default(0)
  rank          Int?
  coinsAwarded  Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([userId, weekNumber, cefrLevel])
}

model SharedDeck {
  id           String   @id @default(cuid())
  creatorId    String
  words        String[]
  locationLat  Float
  locationLng  Float
  locationName String
  isActive     Boolean  @default(true)
  publishedAt  DateTime @default(now())
  expiresAt    DateTime
}

model UserConsent {
  id              String   @id @default(cuid())
  userId          String   @unique
  photos          Boolean  @default(true)
  gps             Boolean  @default(true)
  sessionBehavior Boolean  @default(true)
  voiceRecording  Boolean  @default(false)
  consentedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ipAddress       String?
}
